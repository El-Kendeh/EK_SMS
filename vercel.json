  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "REACT_APP_API_URL": "https://ek-sms-backend.onrender.com",
    "REACT_APP_ENVIRONMENT": "production"
  }
}
